# Always include platform-optional dependencies in the lockfile.
# Without this, `npm install` on one OS can drop packages that another OS
# (notably the GitHub Actions Linux runner) needs at `npm ci` time —
# a known npm 11 lock-completeness quirk that bit us with @emnapi/* on
# the @napi-rs/wasm-runtime tree.
include=optional
audit=false
fund=false
